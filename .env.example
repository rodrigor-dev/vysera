# ============================================================================
# VYSERA PLATFORM - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# --- DATABASE ---
DATABASE_URL="postgresql://user:password@host:5432/vysera?schema=public"

# --- SUPABASE (Frontend Auth) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- JWT ---
JWT_SECRET="your-jwt-secret-key-at-least-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-at-least-32-characters"
JWT_REFRESH_EXPIRES_IN="7d"

# --- ENCRYPTION ---
ENCRYPTION_KEY="your-32-char-encryption-key-here!!!!!"

# --- REDIS (Upstash) ---
REDIS_URL="redis://default:password@your-region.upstash.io:6379"
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# --- OAUTH PROVIDERS ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# --- EMAIL (SendGrid / Resend) ---
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="noreply@vysera.com"

# --- STRIPE ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRO_PRICE_ID="price_..."

# --- CORS ---
CORS_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- FILE UPLOADS ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=524288000
ALLOWED_MIME_TYPES="video/mp4,video/quicktime,video/webm,image/jpeg,image/png,image/webp"

# --- SECURITY ---
SESSION_EXPIRY_HOURS=24
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
BCRYPT_SALT_ROUNDS=12

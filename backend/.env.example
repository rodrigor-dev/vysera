# ============================================================================
# VYSERA BACKEND - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# --- SERVER ---
PORT=4000
NODE_ENV=development

# --- DATABASE (PostgreSQL via Supabase) ---
DATABASE_URL="postgresql://user:password@host:5432/vysera?schema=public"

# --- SUPABASE (Auth & Storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- JWT (REQUIRED in production - generate secure random strings) ---
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_REFRESH_EXPIRES_IN="7d"

# --- ENCRYPTION (REQUIRED in production - AES-256-GCM key) ---
ENCRYPTION_KEY="change-me-to-exactly-32-chars!!!!!!"

# --- CORS ---
CORS_ORIGIN="http://localhost:3000"

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- FILE UPLOADS ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=524288000
ALLOWED_MIME_TYPES="video/mp4,video/quicktime,video/webm,image/jpeg,image/png,image/webp"

# --- SECURITY ---
SESSION_EXPIRY_HOURS=24
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
BCRYPT_SALT_ROUNDS=12

# --- STRIPE ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# --- MERCADO PAGO ---
MP_ACCESS_TOKEN="TEST-..."
MP_WEBHOOK_SECRET="your-mp-webhook-secret"

# --- REDIS / UPSTASH (optional - falls back to in-memory) ---
REDIS_URL="redis://default:password@your-region.upstash.io:6379"
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# --- EMAIL (SendGrid / Resend) ---
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="noreply@vysera.com"

# --- OAUTH PROVIDERS ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  pro
  admin
}

enum ProjectStatus {
  draft
  processing
  completed
  failed
}

enum ExportFormat {
  mp4
  mov
  webm
  gif
}

enum ExportResolution {
  p720
  p1080
  k2
  k4
}

enum ExportStatus {
  pending
  queued
  rendering
  processing
  completed
  failed
  cancelled
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   Boolean   @default(false)
  passwordHash    String?
  name            String?
  avatarUrl       String?
  role            UserRole  @default(user)
  stripeCustomerId String?
  stripeSubscriptionId String?
  mpCustomerId    String?
  mpSubscriptionId String?
  proExpiresAt    DateTime?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  projects       Project[]
  templates      Template[]
  exports        Export[]
  uploads        Upload[]
  auditLogs      AuditLog[]
  loginAttempts  LoginAttempt[]
  paymentHistory PaymentHistory[]
  subscriptions  Subscription[]
  invoices       Invoice[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  status      ProjectStatus @default(draft)
  thumbnail   String?
  duration    Int?
  resolution  String?
  fps         Int?
  metadata    Json?
  tags        String[]
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exports  Export[]
  uploads  Upload[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([isArchived])
  @@map("projects")
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  thumbnail   String?
  category    String?
  config      Json
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@map("templates")
}

model Export {
  id          String           @id @default(cuid())
  projectId   String
  userId      String
  format      ExportFormat     @default(mp4)
  resolution  ExportResolution @default(p1080)
  quality     String?
  fps         Int              @default(30)
  codec       String           @default("h264")
  platform    String?
  fileUrl     String?
  fileSize    Int?
  duration    Int?
  status      ExportStatus     @default(pending)
  error       String?
  progress    Float            @default(0)
  stage       String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("exports")
}

model Upload {
  id          String   @id @default(cuid())
  projectId   String?
  userId      String
  fileName    String
  originalName String
  mimeType    String
  size        Int
  url         String
  thumbnail   String?
  duration    Int?
  width       Int?
  height      Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([mimeType])
  @@index([createdAt])
  @@map("uploads")
}

model PaymentHistory {
  id              String   @id @default(cuid())
  userId          String
  stripePaymentId String?
  amount          Int
  currency        String   @default("usd")
  status          String
  plan            String?
  description     String?
  metadata        Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripePaymentId])
  @@index([status])
  @@index([createdAt])
  @@index([plan])
  @@map("payment_history")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType])
  @@index([entityId])
  @@map("audit_logs")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([ip])
  @@index([createdAt])
  @@map("login_attempts")
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String
  severity  String   @default("info")
  message   String
  metadata  Json?
  ip        String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@map("security_events")
}

model ProcessingJob {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?
  status      String    @default("queued")
  progress    Float     @default(0)
  stage       String?
  format      String?
  template    String?
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  options     Json?
  result      Json?
  error       String?
  inputFiles  String[]
  outputPath  String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("processing_jobs")
}

enum SubscriptionProvider {
  stripe
  mercadopago
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  expired
}

model Subscription {
  id                     String               @id @default(cuid())
  userId                 String
  provider               SubscriptionProvider
  providerSubscriptionId String?
  providerCustomerId     String?
  plan                   String               @default("pro")
  status                 SubscriptionStatus   @default(active)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialEndsAt            DateTime?
  canceledAt             DateTime?
  metadata               Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([provider, providerSubscriptionId])
  @@index([userId])
  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

model Invoice {
  id              String               @id @default(cuid())
  userId          String
  subscriptionId  String?
  provider        SubscriptionProvider
  providerInvoiceId String?
  amount          Int
  currency        String               @default("usd")
  status          String               @default("paid")
  description     String?
  paymentMethod   String?
  paidAt          DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([providerInvoiceId])
  @@map("invoices")
}

model AppConfig {
  id    String @id @default("default")
  key   String @unique
  value Json
  type  String @default("string")

  @@index([key])
  @@map("app_config")
}
